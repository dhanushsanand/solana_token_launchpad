generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User{
  id Int @id @default(autoincrement())
  email String @unique
  password String
  name String
  createdAt DateTime @default(now())
  launches Launch[]
  purchases Purchase[]
}

model Launch{
  id Int @id @default(autoincrement())
  name String
  symbol String
  totalSupply Float
  pricePerToken Float
  startsAt DateTime
  endsAt DateTime
  maxPerWallet Float
  description String?
  createdAt DateTime @default(now())

  creatorId Int
  creator User @relation(fields: [creatorId], references: [id])
  tiers Tier[]
  vesting VestingConfig?
  whitelist WhitelistEntry[]
  referralCode ReferralCode[]
  purchases Purchase[]
}

model Tier{
  id Int @id @default(autoincrement())
  minAmount Float
  maxAmount Float
  pricePerToken Float
  launchId Int
  launch Launch @relation(fields: [launchId], references: [id])
}

model VestingConfig{
  id Int @id @default(autoincrement())
  cliffDays Int 
  vestingDays Int
  tgePercent Float
  launchId Int @unique
  launch Launch @relation(fields: [launchId], references: [id])
}

model WhitelistEntry{
  id Int @id @default(autoincrement())
  address String

  launchId Int
  launch Launch @relation(fields:[launchId], references: [id])

  @@unique([launchId, address])
}

model ReferralCode{
  id Int @id @default(autoincrement())
  code String
  discountPercent Float
  maxUses Int
  usedCount Int @default(0)
  launchId Int
  launch Launch @relation(fields: [launchId], references: [id])
  @@unique([launchId, code])
}

model Purchase{
  id Int @id @default(autoincrement())
  walletAddress String
  amount Float
  totalCost Float
  txSignature String @unique
  createdAt DateTime @default(now())
  launchId Int
  launch Launch @relation(fields: [launchId], references:[id])
  userId Int
  user User @relation(fields: [userId], references:[id])
}

